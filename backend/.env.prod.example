DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=<set-in-render>
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=<backend-service>.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=https://<frontend-service>.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://<frontend-service>.onrender.com
DJANGO_TIME_ZONE=America/Chicago
FRONTEND_BASE_URL=https://<frontend-service>.onrender.com
BACKEND_PUBLIC_BASE_URL=https://<backend-service>.onrender.com
FRONTEND_AUTH_VERIFY_EMAIL_URL=
FRONTEND_AUTH_PASSWORD_RESET_URL=
FRONTEND_AUTH_PASSWORD_RESET_KEY_URL=
FRONTEND_AUTH_SIGNUP_URL=
FRONTEND_AUTH_ERROR_URL=
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
GOOGLE_CLIENT_ID=<set-in-render>
GOOGLE_CLIENT_SECRET=<set-in-render>
GOOGLE_TOKEN_ENCRYPTION_KEY=<optional-fernet-key>
OPENAI_API_KEY=<set-in-render>
AGNO_MODEL_ID=gpt-5-mini
INNGEST_APP_ID=cal-assistant-backend
INNGEST_BASE_URL=<set-if-using-inngest-cloud-or-service>
INNGEST_EVENT_KEY=<set-if-used>
INNGEST_SIGNING_KEY=<set-if-used>
INNGEST_SERVE_ORIGIN=https://<backend-service>.onrender.com
INNGEST_SERVE_PATH=/api/inngest
GOOGLE_CALENDAR_WEBHOOK_ADDRESS=
GOOGLE_CALENDAR_WEBHOOK_TTL_SECONDS=604800
POSTGRES_ENABLED=true
POSTGRES_DB=<render-postgres-db>
POSTGRES_USER=<render-postgres-user>
POSTGRES_PASSWORD=<set-in-render>
POSTGRES_HOST=<render-postgres-host>
POSTGRES_PORT=5432
LOG_LEVEL=INFO
